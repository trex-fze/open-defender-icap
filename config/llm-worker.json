{
  "queue_name": "classification-jobs",
  "redis_url": "redis://redis:6379",
  "cache_channel": "od:cache:invalidate",
  "stream": "classification-jobs",
  "database_url": "postgres://defender:defender@postgres:5432/defender_admin",
  "providers": [
    {
      "name": "mock-openai",
      "type": "openai",
      "endpoint": "http://mock-openai:8080/v1/chat/completions",
      "model": "mock-gpt",
      "timeout_ms": 10000
    }
  ],
  "routing": {
    "default": "mock-openai",
    "fallback": "mock-openai",
    "policy": "failover"
  },
  "metrics_host": "0.0.0.0",
  "metrics_port": 19015
}
