{
  "queue_name": "classification-jobs",
  "redis_url": "redis://redis:6379",
  "cache_channel": "od:cache:invalidate",
  "stream": "classification-jobs",
  "database_url": "postgres://defender:defender@postgres:5432/defender_admin",
  "providers": [
    {
      "name": "local-lmstudio",
      "type": "lm_studio",
      "endpoint": "http://192.168.1.170:1234/v1/chat/completions",
      "model": "gpt-oss-120b",
      "timeout_ms": 15000
    },
    {
      "name": "openai-fallback",
      "type": "openai",
      "endpoint": "https://api.openai.com/v1/chat/completions",
      "model": "gpt-4o-mini",
      "api_key_env": "OPENAI_API_KEY",
      "timeout_ms": 10000
    }
  ],
  "routing": {
    "default": "local-lmstudio",
    "fallback": "openai-fallback",
    "policy": "safe",
    "primary_retry_max": 3,
    "primary_retry_backoff_ms": 500,
    "primary_retry_max_backoff_ms": 5000,
    "retryable_status_codes": [408, 429, 500, 502, 503, 504],
    "fallback_cooldown_secs": 30,
    "fallback_max_per_min": 30,
    "stale_pending_minutes": 0,
    "stale_pending_online_provider": "openai-fallback",
    "stale_pending_health_ttl_secs": 30,
    "stale_pending_max_per_min": 10,
    "online_context_mode": "required",
    "metadata_only_force_action": "Monitor",
    "metadata_only_max_confidence": 0.4,
    "metadata_only_requeue_for_content": true,
    "content_required_mode": "auto",
    "metadata_only_allowed_for": "all",
    "metadata_only_fetch_failure_threshold": 2,
    "metadata_only_no_content_statuses": ["failed", "unsupported", "blocked"],
    "pending_reconcile_enabled": true,
    "pending_reconcile_interval_secs": 60,
    "pending_reconcile_stale_minutes": 10,
    "pending_reconcile_batch": 100
  },
  "metrics_host": "0.0.0.0",
  "metrics_port": 19015
}
