# Open Defender production-like environment template (repo root)
#
# Usage:
#   cp .env-prod.example .env-prod
#   # set strong unique secrets before start
#   make MODE=prod preflight
#   make MODE=prod start

OD_ALLOW_INSECURE_DEV_SECRETS=false

# Core infra credentials
POSTGRES_USER=svc_admin
POSTGRES_PASSWORD=<set-strong-postgres-password>
POSTGRES_DB=defender
REDIS_PASSWORD=<set-strong-redis-password>
ELASTIC_PASSWORD=<set-strong-elastic-password>
ELASTICSEARCH_SERVICEACCOUNTTOKEN=<set-kibana-service-account-token>

# Control-plane tokens and auth
OD_ADMIN_TOKEN=<set-strong-admin-token>
OD_POLICY_ADMIN_TOKEN=<set-strong-policy-admin-token>
OD_AUTH_MODE=local
OD_LOCAL_AUTH_JWT_SECRET=<set-strong-local-jwt-secret-32-plus>
OD_DEFAULT_ADMIN_PASSWORD=<set-strong-bootstrap-admin-password>

# Database and Redis URLs (must include credentials)
OD_ADMIN_DATABASE_URL=postgres://svc_admin:<set-strong-postgres-password>@postgres:5432/defender_admin
OD_POLICY_DATABASE_URL=postgres://svc_admin:<set-strong-postgres-password>@postgres:5432/defender_admin
OD_TAXONOMY_DATABASE_URL=postgres://svc_admin:<set-strong-postgres-password>@postgres:5432/defender_admin
OD_CACHE_REDIS_URL=redis://:<set-strong-redis-password>@redis:6379
OD_PAGE_FETCH_REDIS_URL=redis://:<set-strong-redis-password>@redis:6379

# Service URLs and ingestion
OD_ADMIN_URL=http://admin-api:19000
OD_POLICY_URL=http://policy-engine:19010
OD_POLICY_ENGINE_URL=http://policy-engine:19010
OD_IAM_RESOLVER_URL=http://admin-api:19000/api/v1/iam/whoami
OD_FILEBEAT_SECRET=<set-strong-filebeat-shared-secret>
OD_ELASTIC_URL=http://elasticsearch:9200
OD_ELASTIC_USERNAME=elastic
OD_ELASTIC_PASSWORD=<set-strong-elastic-password>

# Optional provider credentials
OPENAI_API_KEY=
LLM_API_KEY=
