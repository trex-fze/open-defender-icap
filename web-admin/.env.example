# Optional web-admin standalone dev environment
# Used when running `npm run dev` directly inside web-admin.
# `VITE_ADMIN_TOKEN_MODE` values:
# - auto   : infer Bearer for JWT-looking tokens, otherwise X-Admin-Token
# - bearer : always send Authorization: Bearer <token>
# - token  : always send X-Admin-Token: <token>

VITE_ADMIN_API_URL=
VITE_ADMIN_API_FALLBACK=
VITE_ADMIN_TOKEN_MODE=auto
VITE_LLM_PROVIDERS_URL=
VITE_ADMIN_API_PROXY_TARGET=http://localhost:19000
VITE_HTTPS_ENABLED=false
VITE_HTTPS_CERT_FILE=
VITE_HTTPS_KEY_FILE=
