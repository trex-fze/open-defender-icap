# Core service credentials (override in local .env)
POSTGRES_USER=defender
POSTGRES_PASSWORD=defender
POSTGRES_DB=defender

# Admin / cache wiring
OD_ADMIN_TOKEN=changeme-admin
OD_ADMIN_DATABASE_URL=postgres://defender:defender@postgres:5432/defender_admin
OD_POLICY_DATABASE_URL=postgres://defender:defender@postgres:5432/defender_admin
OD_ADMIN_CORS_ALLOW_ORIGIN=http://localhost:19001
OD_CACHE_REDIS_URL=redis://redis:6379
OD_CACHE_CHANNEL=od:cache:invalidate
OD_OIDC_ISSUER=
OD_OIDC_AUDIENCE=
OD_OIDC_HS256_SECRET=
OD_AUTH_MODE=local
OD_LOCAL_AUTH_JWT_SECRET=changeme-local-jwt-secret
OD_DEFAULT_ADMIN_PASSWORD=changeme-local-admin-password
OD_LOCAL_AUTH_TTL_SECONDS=3600
OD_LOCAL_AUTH_MAX_FAILED_ATTEMPTS=5
OD_LOCAL_AUTH_LOCKOUT_SECONDS=900
OD_REVIEW_SLA_SECONDS=14400
OD_AUDIT_ELASTIC_URL=
OD_AUDIT_ELASTIC_INDEX=audit-events
OD_AUDIT_ELASTIC_API_KEY=

# Page fetcher (content capture)
OD_PAGE_FETCH_REDIS_URL=redis://redis:6379
OD_PAGE_FETCH_STREAM=page-fetch-jobs
OD_PAGE_FETCH_TTL_SECONDS=21600

# Policy engine defaults
OD_POLICY_URL=http://policy-engine:19010
OD_ADMIN_URL=http://admin-api:19000

# Elastic / Kibana
ELASTIC_PASSWORD=changeme-elastic

# Misc
RUST_LOG=info
